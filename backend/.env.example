# ============================================================
#  .env.example — Variables de entorno para el backend
#  Copia como .env en el servidor AWS y rellena los valores
# ============================================================

# ── Administradores del panel ────────────────────────────────
# Lista de emails separados por coma. Soporta ñ, tildes y cualquier
# carácter UTF-8 (Linux/AWS usa UTF-8 en env vars por defecto).
# Ejemplo con ñ: nuñez@iescomercio.com,gsoriano@iescomercio.com
ADMIN_EMAILS=gsoriano@iescomercio.com

# ── PostgreSQL en AWS ────────────────────────────────────────
DATABASE_URL=postgresql://chatbot_user:TU_PASSWORD@localhost:5432/chatbot_db

# ── Modelo fine-tuneado LOCAL (Qwen2.5-1.5B-QLoRA) ──────────
# El modelo se carga directamente con transformers desde disco.
# No se necesita ningún servidor externo (TGI, vLLM, Ollama).
MODEL_PROVIDER=local

# Ruta donde está guardado el modelo fine-tuneado en la instancia:
#   - si el backend corre como Docker: es la ruta dentro del contenedor
#     (mapeada con -v /home/ubuntu/modelo/qwen_finetuned:/modelo/qwen_finetuned)
#   - si corre directamente: ruta absoluta en el sistema de archivos
LOCAL_MODEL_PATH=/modelo/qwen_finetuned

# ── ChromaDB ─────────────────────────────────────────────────
# Ruta absoluta a la carpeta chroma_db (como se ve en el CI/CD):
CHROMA_DB_PATH=/app/datalake/datalake/artifacts/chroma_db
CHROMA_COLLECTION=convozpropia
RAG_N_RESULTS=3

# ── Parámetros de generación ─────────────────────────────────
MAX_NEW_TOKENS=256
MODEL_TIMEOUT_S=60

# ── HF Token (solo si MODEL_PROVIDER=hf, no necesario en local) ──
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
