# ============================================================
#  .env.example — Variables de entorno para el backend
#  Copia como .env en el servidor AWS y rellena los valores
# ============================================================

# ── PostgreSQL en AWS ────────────────────────────────────────
# Formato: postgresql://usuario:password@host:puerto/nombre_db
DATABASE_URL=postgresql://chatbot_user:TU_PASSWORD@localhost:5432/chatbot_db

# ── Modelo fine-tuneado LOCAL en la instancia AWS ────────────
#
# Elige el MODEL_PROVIDER según cómo hayas arrancado el modelo:
#
# Si usas Text Generation Inference (TGI):
MODEL_PROVIDER=tgi
MODEL_API_URL=http://localhost:8080
MODEL_NAME=inyxpa/chatbot
#
# Si usas vLLM (OpenAI-compatible):
# MODEL_PROVIDER=openai
# MODEL_API_URL=http://localhost:8000
# MODEL_NAME=/ruta/local/al/modelo  o  inyxpa/chatbot
#
# Si usas Ollama:
# MODEL_PROVIDER=ollama
# MODEL_API_URL=http://localhost:11434
# MODEL_NAME=chatbot  (nombre que pusiste en ollama pull/create)

# ── Parámetros de generación ─────────────────────────────────
MAX_NEW_TOKENS=256
MODEL_TIMEOUT_S=60

# ── HF Token (solo necesario si MODEL_PROVIDER=hf) ──────────
# En producción con modelo local, puedes dejarlo vacío o comentarlo
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── ChromaDB (ruta absoluta dentro de la instancia AWS) ──────
# Si el backend corre en /app/, la ruta por defecto es correcta.
# Cambia solo si ChromaDB está en una ruta diferente:
# CHROMA_DB_PATH=/app/datalake/artifacts/chroma_db
# CHROMA_COLLECTION=convozpropia
# RAG_N_RESULTS=3
