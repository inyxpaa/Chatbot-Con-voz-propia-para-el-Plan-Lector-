# ============================================================
#  .env.example — Variables de entorno para el backend
#  Copia este archivo como .env y ajusta los valores
# ============================================================

# ── Base de datos PostgreSQL (AWS RDS) ──────────────────────
DATABASE_URL=postgresql://usuario:password@host-rds.amazonaws.com:5432/chatbot_db

# ── Hugging Face Token (necesario si MODEL_PROVIDER=hf) ────
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Configuración del modelo ────────────────────────────────
#
# MODEL_PROVIDER controla el formato de la petición al modelo:
#   hf     → HF Inference API (cloud) o TGI con mismo formato
#   tgi    → Text Generation Inference local (mismo que hf)
#   openai → Compatible con OpenAI (vLLM, LM Studio, etc.)
#   ollama → Ollama local
#
# MODEL_API_URL es la URL base del endpoint del modelo:
#   - HF cloud  : (dejar vacío, se usa la URL por defecto)
#   - TGI local en AWS  : http://localhost:8080
#   - vLLM local en AWS : http://localhost:8000  (y provider=openai)
#   - Ollama            : http://localhost:11434  (y provider=ollama)

MODEL_PROVIDER=hf
# MODEL_API_URL=http://localhost:8080

# Nombre del modelo (para OpenAI-compat y Ollama)
# MODEL_NAME=inyxpa/chatbot

# ── Parámetros de generación ────────────────────────────────
MAX_NEW_TOKENS=256
MODEL_TIMEOUT_S=30
